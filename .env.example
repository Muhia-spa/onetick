# Database
DB_NAME=onetick
DB_USERNAME=onetick
DB_PASSWORD=onetick

# App Security
APP_JWT_SECRET=replace-with-a-64-char-random-secret

# Redis (notifications queue)
REDIS_HOST=localhost
REDIS_PORT=6379
APP_NOTIFICATIONS_QUEUE_BACKEND=redis
APP_NOTIFICATIONS_QUEUE_DLQ_KEY=onetick:notifications:dlq
APP_NOTIFICATIONS_QUEUE_MAX_RETRIES=3
APP_NOTIFICATIONS_QUEUE_BACKOFF_BASE_MS=2000
APP_NOTIFICATIONS_QUEUE_BACKOFF_MAX_MS=30000

# Redis cache
CACHE_REDIS_TTL_MS=60000

# Auth0 OIDC
APP_OIDC_AUTH0_ENABLED=false
APP_OIDC_AUTH0_DOMAIN=your-tenant.us.auth0.com
APP_OIDC_AUTH0_CLIENT_ID=your-client-id
APP_OIDC_AUTH0_CLIENT_SECRET=your-client-secret
APP_OIDC_AUTH0_AUDIENCE=
APP_OIDC_AUTH0_REDIRECT_URI=http://localhost:8080/api/v1/auth/oidc/callback
APP_OIDC_AUTH0_SCOPES=openid profile email
APP_OIDC_AUTH0_GROUP_CLAIM=groups
APP_OIDC_AUTH0_STATE_TTL_MS=300000

# Optional bootstrap admin for first-time setup
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_EMAIL=admin@onetick.local
APP_BOOTSTRAP_ADMIN_NAME=Onetick Admin
APP_BOOTSTRAP_ADMIN_PASSWORD=admin12345
